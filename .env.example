# Azure AD — app registration with client credentials (app-only) auth
# Requires a Microsoft 365 work/school account and an app registered in Azure AD
# Grant the app these Graph API application permissions:
#   Files.Read.All   (to download recordings from OneDrive)
#   Mail.ReadWrite   (to create drafts in Outlook)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# UPN or object ID of the user whose OneDrive is monitored for recordings
ONEDRIVE_USER_ID=

# UPN or object ID of the user whose Outlook drafts folder receives the output
# May be the same as ONEDRIVE_USER_ID
MAIL_USER_ID=

# LLM provider for transcript analysis — "anthropic" (default) or "openai"
MODEL_PROVIDER=anthropic

# Anthropic (Claude) — required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (ChatGPT) — required when MODEL_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Groq (Whisper) — used for audio transcription
GROQ_API_KEY=
